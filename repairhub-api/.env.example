# SMTP / Mail settings (Hostinger example)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=your@domain.com
SMTP_PASS=your_smtp_password
SMTP_SECURE=false

# From email
FROM_EMAIL=no-reply@yourdomain.com

# Frontend or app url (used in email links)
APP_URL=https://app.yourdomain.com
# ==================== DATABASE ====================
# Configuración de PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=repairhub
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ==================== APPLICATION ====================
# Configuración de la aplicación
PORT=3000
NODE_ENV=development

# ==================== JWT AUTHENTICATION ====================
# Para Usuario Admin/Master
# Generar con: openssl rand -base64 48
JWT_SECRET=changeme_min_64_characters_use_openssl_rand_base64_48
JWT_EXPIRES_IN=7d

# Para Empleados (acceso limitado)
JWT_EMPLOYEE_SECRET=changeme_min_64_characters_use_openssl_rand_base64_48
JWT_EMPLOYEE_EXPIRES_IN=1d

# ==================== SECURITY ====================
# Bcrypt rounds (10-12 recomendado, mayor = más seguro pero más lento)
BCRYPT_ROUNDS=12

# ==================== CORS ====================
# Orígenes permitidos (separados por comas)
CORS_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS,HEAD
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Requested-With,X-API-Key,X-Client-Version,X-Platform
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# ==================== EMAIL (OPCIONAL) ====================
# Para envío de emails (usar tu servicio SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_app_password
EMAIL_FROM=noreply@repairhub.com

# ==================== LOGS ====================
# Nivel de log: error, warn, log, debug, verbose
LOG_LEVEL=log
LOG_FORMAT=json

# ==================== STORAGE (SUPABASE / LOCAL) ====================
# STORAGE_PROVIDER can be 'local' or 'supabase'. If unset, SUPABASE_ENABLED=true implies supabase.
# Use SUPABASE for storing uploads remotely (recommended for production).
STORAGE_PROVIDER=local
# When using Supabase storage set the following:
SUPABASE_ENABLED=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=public

# ==================== GOOGLE CLOUD STORAGE / MEDIA ====================
# Bucket privado para imagenes comprimidas.
GCS_BUCKET=repairhub-images
GCS_PROJECT_ID=

# Recomendado para Railway: JSON completo de service account en una sola linea.
GCS_CREDENTIALS_JSON=

# Alternativa local: ruta a archivo JSON de service account.
GCS_KEY_FILE=

GCS_SIGNED_URL_EXPIRES_SECONDS=3600
IMAGE_MAX_COUNT=6
IMAGE_MAX_INPUT_BYTES=5242880
IMAGE_DISPLAY_MAX_WIDTH=1280
IMAGE_DISPLAY_MAX_BYTES=204800
IMAGE_DISPLAY_QUALITY=75
IMAGE_DISPLAY_MIN_QUALITY=55
IMAGE_THUMBNAIL_MAX_WIDTH=320
IMAGE_THUMBNAIL_MAX_BYTES=25600
IMAGE_THUMBNAIL_QUALITY=60
IMAGE_THUMBNAIL_MIN_QUALITY=45
SHARP_CONCURRENCY=1
