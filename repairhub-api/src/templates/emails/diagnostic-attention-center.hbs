<!doctype html>
<html style="color-scheme: light only; supported-color-schemes: light;">
  <head>
    <meta charset="utf-8" />
    <meta name="color-scheme" content="light only" />
    <meta name="supported-color-schemes" content="light" />
    <title>Attention Required: Diagnostic Added</title>
  </head>
  <body bgcolor="#f6f7f9" style="margin: 0; padding: 0; background: #f6f7f9; background-color: #f6f7f9; font-family: Arial, sans-serif; color: #222;">
    <div style="max-width: 640px; margin: 0 auto; padding: 28px 16px;">
      <div style="background: #ffffff; border: 1px solid #e7e7e7; border-radius: 8px; overflow: hidden;">
        <img src="cid:logo@repairhub" alt="Miami Photography Center" style="display: block; width: 100%; max-width: 640px; height: auto; margin: 0;" />
        <div style="padding: 30px;">
          <h1 style="margin: 0 0 18px 0; font-size: 22px; line-height: 1.3; color: #111111;">Attention Required: Diagnostic Added</h1>
          <p style="margin: 0 0 14px 0; font-size: 15px; line-height: 1.6;">Dear Center Team,</p>
          <p style="margin: 0 0 14px 0; font-size: 15px; line-height: 1.6;">
            A diagnostic update has been added to service order <strong>#{{orderCode}}</strong> and requires your review.
          </p>
          <div style="background: #fafafa; border: 1px solid #eeeeee; border-radius: 6px; padding: 16px; margin: 20px 0;">
            <p style="margin: 0 0 8px 0; font-size: 13px; line-height: 1.5; color: #666666;"><strong>Diagnostic</strong></p>
            <p style="margin: 0; font-size: 15px; line-height: 1.6;">{{diagnostic}}</p>
          </div>
          <p style="margin: 0 0 8px 0; font-size: 14px; line-height: 1.6; color: #666666;"><strong>Customer:</strong> {{customerName}}</p>
          <p style="margin: 0 0 22px 0; font-size: 14px; line-height: 1.6; color: #666666;"><strong>Date:</strong> {{date}}</p>
          <div style="border-top: 1px solid #ececec; margin: 24px 0;"></div>
          <p style="margin: 0 0 24px 0; font-size: 15px; line-height: 1.6;">Please review the order and take the necessary actions.</p>
          <p style="margin: 0; font-size: 15px; line-height: 1.6;">
            Best regards,<br />
            <strong>Miami Photography Center</strong><br />
            <span style="color: #0056b3;">MPC System</span>
          </p>
        </div>
      </div>
      <div style="padding: 16px 8px 0 8px; font-size: 12px; line-height: 1.5; color: #999999; text-align: center;">
        This is an automated notification message.
      </div>
    </div>
  </body>
</html>
